# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://activia:activia@localhost:5432/activia

# Test database (use a separate DB for pytest; same host/credentials)
TEST_DATABASE_URL=postgresql+asyncpg://activia:activia@localhost:5432/activia_test

# JWT signing secret (minimum 32 characters)
SECRET_KEY=change-me-use-at-least-32-characters-long

# AES-256 encryption key (exactly 32 characters)
ENCRYPTION_KEY=01234567890123456789012345678901

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# OpenTelemetry (optional; app starts without an OTLP exporter)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=activia-trace-api

# Comma-separated browser origins allowed for the SPA (C-21)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Login brute-force protection (disable locally for dev comfort)
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
